      "source": [
        "# Open the file in 'w' (write) mode\n",
        "f=open(\"example.txt\", \"w\")\n",
        "\n",
        "lines_list = []\n",
        "\n",
        "print(\"Enter 20 lines:\")\n",
        "\n",
        "for i in range(1, 21):\n",
        "    line = input()\n",
        "    lines_list.append(line + \"\\n\")\n",
        "\n",
        "# Now write the entire list at once\n",
        "f.writelines(lines_list)\n",
        "\n",
        "print(\"Successfully written\")\n",
        "f.close()"
      ]
    }
  ]
